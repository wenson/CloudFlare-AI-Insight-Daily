name = "ai-daily"
main = "src/index.js"
compatibility_date = "2025-05-20"
workers_dev = true

[[kv_namespaces]]
binding = "DATA_KV"
id = "replace-with-your-kv-namespace-id"

[[d1_databases]]
binding = "DB"
database_name = "ai-daily"
database_id = "replace-with-your-d1-database-id"

[vars]
IMG_PROXY = ""
OPEN_TRANSLATE = "true"
USE_MODEL_PLATFORM = "GEMINI"
GEMINI_API_URL = "https://generativelanguage.googleapis.com"
DEFAULT_GEMINI_MODEL = "gemini-2.5-flash-preview-05-20"
OPENAI_API_URL = "https://api.openai.com"
DEFAULT_OPEN_MODEL = "your-openai-compatible-model"
FOLO_COOKIE_KV_KEY = "folo_auth_cookie"
FOLO_DATA_API = "https://api.follow.is/entries"
FOLO_FILTER_DAYS = "7"
FOLO_WEBHOOK_TOKEN = ""
FOLO_WEBHOOK_FEED_MAP = "[]"
NEWS_AGGREGATOR_LIST_ID = ""
NEWS_AGGREGATOR_FETCH_PAGES = "20"
HGPAPERS_LIST_ID = ""
HGPAPERS_FETCH_PAGES = "1"
TWITTER_LIST_ID = ""
TWITTER_FETCH_PAGES = "1"
REDDIT_LIST_ID = ""
REDDIT_FETCH_PAGES = "1"
DAILY_TITLE = "AI洞察日报"
DAILY_TITLE_MIN = "`AI 日报`"
PODCAST_TITLE = "来生小酒馆"
PODCAST_BEGIN = "嘿，亲爱的V，欢迎收听新一期的来生情报站，我是你们的老朋友，何夕2077"
PODCAST_END = "今天的情报就到这里，注意隐蔽，赶紧撤离"
INSERT_FOOT = "false"
INSERT_AD = "false"
INSERT_APP_URL = "<h3>[查看完整版AI日报↗️ https://ai.hubtoday.app/](https://ai.hubtoday.app/)</h3>"

[triggers]
crons = ["10 0 * * *"]
